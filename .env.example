# PreMed Connect — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must NEVER be committed.

# ── Frontend (VITE_ prefix = bundled into the browser) ──────────────────────
# These are intentionally public. They are protected by Supabase RLS policies.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
VITE_PAYSTACK_PUBLIC_KEY=pk_live_<your-paystack-public-key>

# ── Backend / local scripts only (NO VITE_ prefix) ──────────────────────────
# WARNING: These secrets grant admin access. Never add a VITE_ prefix.
# They are read only by bootstrap.mjs (local Node script) and Supabase Edge
# Functions (which receive them via the Supabase secrets vault, not this file).
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Edge Function secrets (set via `supabase secrets set`, not this file) ────
# These are listed here for documentation only. They are injected into Deno
# Edge Functions at runtime and are never stored in this file in production.
# RESEND_API_KEY=re_<your-resend-api-key>
# PAYSTACK_SECRET_KEY=sk_live_<your-paystack-secret-key>
# APP_URL=https://premedconnect.xyz
